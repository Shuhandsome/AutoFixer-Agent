# Your LLM API Key (Supports OpenAI, DeepSeek, SiliconFlow, and other compatible APIs)
OPENAI_API_KEY=your_api_key_here
# API Base URL, modify this if using DeepSeek or a proxy
OPENAI_BASE_URL=https://api.openai.com/v1
# Recommended to use a highly capable model, such as claude-3-5-sonnet, deepseek-reasoner, or gpt-4o
MODEL_NAME=gpt-4o
